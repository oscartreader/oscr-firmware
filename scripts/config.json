{
  "flow": {
    "quick": {
      "name": "Quick",
      "description": "Quick configuration of options, accepting most defaults.",
      "steps": [
        "flag:hardware.version",
        "flag:hardware.atmega",
        "@section:ui",
        "@section:module",
        "flag:output.lcd_type"
      ]
    },
    "standard": {
      "name": "Standard",
      "description": "Standard configuration of options, prompting for the most commonly changed options.",
      "steps": [
        "flag:hardware.version",
        "flag:hardware.atmega",
        "section:ui",
        "@section:module",
        "flag:output.lcd_type"
      ]
    },
    "advanced": {
      "name": "Advanced",
      "description": "Advanced configuration of options, includes asking for some internal flags.",
      "steps": [
        "flag:hardware.version",
        "flag:hardware.atmega",
        "section:ui",
        "section:module",
        "flag:output.lcd_type",
        "flag:output.serial_type"
      ]
    },
    "expert": {
      "name": "Expert",
      "description": "Hand-configure every option allowed.",
      "sections": [
        "flag:hardware.version",
        "flag:hardware.atmega",
        "section:ui",
        "section:module",
        "flag:output.type",
        "flag:output.lcd_type",
        "flag:output.serial_type",
        "flag:input.type"
      ]
    }
  },
  "sections": {
    "module": {
      "name": "Display Module",
      "advanced": true,
      "requires": [{ "ui": "module" }],
      "sets": "module",
      "type": "prompt",
      "enum": {
        "lcd": {
          "name": "LCD",
          "sets": {
            "output": "os12864",
            "input": "rotary",
            "neopixel": true
          }
        },
        "oled1": {
          "name": "OLED + 1 button",
          "sets": {
            "output": "ssd1306",
            "input": "button1",
            "neopixel": false
          }
        },
        "oled2": {
          "name": "OLED + 2 buttons",
          "sets": {
            "output": "ssd1306",
            "input": "button2",
            "neopixel": false
          }
        }
      }
    },
    "ui": {
      "name": "User Interface",
      "advanced": true,
      "type": "prompt",
      "sets": "ui",
      "enum": {
        "module": {
          "name": "Display Module",
          "sets": {
            "ui": "module"
          }
        },
        "serial": {
          "name": "Serial Only",
          "sets": {
            "ui": "serial",
            "output": "serial",
            "input": "serial",
            "module": "serial",
            "neopixel": false
          }
        }
      }
    }
  },
  "flags": {
    "hardware": {
      "version": {
        "name": "Hardware Version",
        "define": "HW_VERSION",
        "sets": "hardware",
        "type": "enum",
        "enum": {
          "hw1": { "name": "Hardware V1", "value": 1, "uses": "hardware.hw1" },
          "hw2": { "name": "Hardware V2", "value": 2, "uses": "hardware.hw2" },
          "hw3": { "name": "Hardware V3", "value": 3, "uses": "hardware.hw3" },
          "hw4": { "name": "Hardware V4", "value": 4, "uses": "hardware.hw4" },
          "hw5": { "name": "Hardware V5", "value": 5, "uses": "hardware.hw5" }
        }
      },
      "neopixel": {
        "name": "NeoPixel",
        "requires": [
          { "module": "lcd" },
          { "module": "serial", "hardware": 5 }
        ],
        "define": "ENABLE_NEOPIXEL",
        "sets": "neopixel",
        "type": "ifdef",
        "ifdef": {
          "yes": {
            "name": "Yes",
            "value": true
          },
          "no": {
            "name": "No",
            "value": false
          }
        }
      },
      "neopixel_order": {
        "name": "NeoPixel Order",
        "requires": [{ "neopixel": true }],
        "define": "OPTION_NEOPIXEL_ORDER",
        "sets": "neopixel:order",
        "type": "enum",
        "enum": {
          "auto": {
            "name": "Auto",
            "value": "NPXL_AUTO"
          },
          "normal": {
            "name": "Normal",
            "value": "NPXL_NORMAL"
          },
          "reverse": {
            "name": "Reverse",
            "value": "NPXL_REVERSE"
          }
        }
      },
      "atmega": {
        "name": "ATmega2560 Type",
        "define": "ENABLE_ONBOARD_ATMEGA",
        "requires": [{ "hardware": 5 }],
        "type": "ifdef",
        "ifdef": {
          "module": {
            "name": "ATmega2560 Module",
            "value": false,
            "sets": { "atmega2560": "integrated" }
          },
          "integrated": {
            "name": "On-Board ATmega2560",
            "value": true,
            "sets": { "atmega2560": "module" }
          }
        }
      },
      "clockgen": {
        "name": "Adafruit Clock Generator (or clone) [CLOCKGEN]",
        "define": "ENABLE_CLOCKGEN",
        "sets": "clockgen",
        "type": "ifdef",
        "ifdef": {
          "yes": {
            "name": "Yes",
            "value": true
          },
          "no": {
            "name": "No",
            "value": false
          }
        }
      },
      "vselect": {
        "name": "Automatic Voltage Select [VSELECT]",
        "define": "ENABLE_VSELECT",
        "requires": [{ "hardware": 5 }],
        "sets": "vselect",
        "type": "ifdef",
        "ifdef": {
          "yes": {
            "name": "Yes",
            "value": true
          },
          "no": {
            "name": "No",
            "value": false
          }
        }
      },
      "rtc": {
        "name": "Real Time Clock [RTC]",
        "define": "ENABLE_RTC",
        "sets": "rtc",
        "type": "ifdef",
        "ifdef": {
          "yes": {
            "name": "Yes",
            "value": true
          },
          "no": {
            "name": "No",
            "value": false
          }
        }
      },
      "rtc_type": {
        "name": "RTC Type",
        "requires": [{ "rtc": true }],
        "define": "RTC_TYPE",
        "sets": "rtc:ic",
        "type": "enum",
        "enum": {
          "ds3231": {
            "name": "DS3231",
            "value": "RTCOPT_DS3231"
          },
          "ds1307": {
            "name": "DS1307",
            "value": "RTCOPT_DS1307"
          }
        }
      }
    },
    "output": {
      "type": {
        "name": "Output Device",
        "define": "HARDWARE_OUTPUT_TYPE",
        "sets": "output",
        "advanced": true,
        "type": "enum",
        "enum": {
          "serial": {
            "name": "Serial",
            "value": "OUTPUT_SERIAL"
          },
          "ssd1306": {
            "name": "OLED (SSD1306)",
            "value": "OUTPUT_SSD1306"
          },
          "os12864": {
            "name": "LCD (OS12864)",
            "value": "OUTPUT_OS12864"
          }
        }
      },
      "lcd_type": {
        "name": "LCD Module Type",
        "define": "OPTION_LCD_TYPE",
        "sets": "module:lcd",
        "requires": [{ "module": "lcd" }],
        "type": "enum",
        "enum": {
          "mks": {
            "name": "MKS MINI 12864",
            "value": "LCD_MKS"
          },
          "btt": {
            "name": "BTT MINI 12864",
            "value": "LCD_BTT"
          },
          "starshade": {
            "name": "StarshadeRETRO OSCR 12864",
            "value": "LCD_SSRETRO"
          }
        }
      },
      "serial_type": {
        "name": "Serial Type",
        "define": "OPTION_SERIAL_OUTPUT",
        "sets": "io:serial",
        "advanced": true,
        "requires": [{ "output": "serial" }],
        "type": "enum",
        "enum": {
          "ascii": {
            "name": "ASCII Serial",
            "value": "SERIAL_ASCII"
          },
          "ansi": {
            "name": "ANSI Serial",
            "value": "SERIAL_ANSI"
          }
        }
      }
    },
    "input": {
      "type": {
        "name": "Input Type",
        "define": "HARDWARE_INPUT_TYPE",
        "sets": "input",
        "advanced": true,
        "type": "enum",
        "enum": {
          "serial": {
            "name": "Serial",
            "value": "OUTPUT_SERIAL",
            "requires": [{ "output": "serial" }]
          },
          "button1": {
            "name": "1-button",
            "value": "INPUT_1BUTTON"
          },
          "button2": {
            "name": "2-button",
            "value": "INPUT_2BUTTON"
          },
          "rotary": {
            "name": "Rotary dial + button",
            "value": "INPUT_ROTARY"
          }
        }
      }
    },
    "features": {
      "language": {
        "name": "Language",
        "define": "OSCR_LANGUAGE",
        "type": "enum",
        "enum": {
          "en": {
            "name": "English",
            "value": "LANG_EN"
          }
        }
      },
      "region": {
        "name": "Region",
