      "unique.method": {
        "name": "Directory Naming Method",
        "define": "OPTION_UNIQUE_DIRECTORY_METHOD",
        "type": "enum",
        "enum": {
          "auto": {
            "name": "Let the firmware decide",
            "value": "UNQDIR_AUTO"
          },
          "increment": {
            "name": "Use an incrementing numeric value",
            "value": "UNQDIR_INCREMENT"
          },
          "rtc": {
            "name": "Use the date/time",
            "value": "UNQDIR_RTC",
            "requires": [{ "rtc": true }]
          },
          "both": {
            "name": "Use the date/time and an incrementing numeric value",
            "value": "UNQDIR_BOTH",
            "requires": [{ "rtc": true }]
          }
        }
      },
