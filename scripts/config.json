          "na": {
            "name": "North America",
            "value": "REGN_NA"
          },
          "eu": {
            "name": "Europe",
            "value": "REGN_EU"
          },
          "as": {
            "name": "Asia (Japan)",
            "value": "REGN_AS"
          }
        }
      },
      "config": {
        "name": "Enable Configuration File",
        "define": "ENABLE_CONFIG",
        "type": "ifdef",
        "ifdef": {
          "yes": {
            "name": "Yes",
            "value": true
          },
          "no": {
            "name": "No",
            "value": false
          }
        }
      },
      "updater": {
        "name": "Enable Updater",
        "define": "ENABLE_UPDATER",
        "requires": [{ "hardware": [3, 5] }],
        "type": "ifdef",
        "ifdef": {
          "yes": {
            "name": "Yes",
            "value": true
          },
          "no": {
            "name": "No",
            "value": false
          }
        }
      },
      "powersaving": {
        "name": "Enable Powersaving",
        "define": "ENABLE_POWERSAVING",
        "type": "ifdef",
        "ifdef": {
          "yes": {
            "name": "Yes",
            "value": true
          },
          "no": {
            "name": "No",
            "value": false
          }
        }
      },
      "debugging": {
        "name": "Enable Debugging",
        "define": ["ENABLE_DEBUG", "ENABLE_CRDB_DEBUG"],
        "type": "ifdef",
        "ifdef": {
          "yes": {
            "name": "Yes",
            "value": true
          },
          "no": {
            "name": "No",
            "value": false
          }
        }
      }
    },
    "options": {
      "lib.sd.fast": {
        "name": "Fast SD (increased idle power)",
        "define": "",
        "type": "def",
        "def": {
          "yes": {
            "name": "Yes",
            "values": {
              "CHECK_FLASH_PROGRAMMING": false
            }
          },
          "no": {
            "name": "No"
          }
        }
      },
      "lib.sd.min": {
        "name": "Minimal SD lib",
        "type": "def",
        "def": {
          "yes": {
            "name": "Yes",
            "values": {
              "SDFAT_FILE_TYPE": 1,
              "USE_FAT_FILE_FLAG_CONTIGUOUS": 0
            }
          },
          "no": {
            "name": "No"
          }
        }
      },
      "lib.sd.utf8": {
        "name": "UTF8 Filenames",
        "define": "USE_UTF8_LONG_NAMES",
        "type": "bool",
        "bool": {
          "yes": {
            "name": "Enable",
            "value": true
          },
          "no": {
            "name": "Disable",
            "value": false
          }
        }
      },
      "lib.sd.dedicated": {
        "name": "SPI Dedicated to SD",
        "define": "ENABLE_DEDICATED_SPI",
        "type": "bool",
        "bool": {
          "yes": {
            "name": "Yes",
            "value": true
          },
          "no": {
            "name": "No",
            "value": false
          }
        }
      },
      "powersaving.methods": {
        "name": "Powersaving Methods",
        "define": "OPTION_POWERSAVING_METHOD",
        "type": "bitflag",
        "bitflags": {
          "display-dim": {
            "name": "Dim Display",
            "flag": "POWERSAVING_DISPLAY_DIM"
          },
          "display-off": {
            "name": "Turn Display Off",
            "flag": "POWERSAVING_DISPLAY_OFF"
          },
          "clock-slow": {
            "name": "Reduce Clock Speed",
            "flag": "POWERSAVING_SLOWCLOCK"
          }
        }
      },
      "powersaving.idle.drowse": {
        "name": "Drowse Time (ms)",
        "define": "OPTION_POWERSAVING_IDLE_DIM",
        "type": "int",
        "int": {
          "min": 30000,
          "max": 120000
        }
      },
      "powersaving.idle.sleep": {
        "name": "Sleep Time (ms)",
        "define": "OPTION_POWERSAVING_IDLE_SLEEP",
        "type": "int",
        "int": {
          "min": 30000,
          "max": 120000
        }
      },
      "performance.flags": {
        "name": "Performance Flags",
        "define": "OPTION_PERFORMANCE_FLAGS",
        "type": "bitflag",
        "bitflags": {
          "inline-crc32": {
            "name": "Fast CRC32",
            "flag": "PRFOPT_CRC32"
          },
          "file-write": {
            "name": "File Write",
            "flag": "PRFOPT_FILEWR"
          },
          "file-read": {
            "name": "File Read",
            "flag": "PRFOPT_FILERD"
          },
          "shared-file": {
            "name": "Shared File Functions",
            "flag": "PRFOPT_SHRDFILE"
          },
          "inline-n64": {
            "name": "N64 Optimizations",
            "flag": "PRFOPT_FAST64"
